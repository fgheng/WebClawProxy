{
  "name": "web-claw-proxy",
  "version": "1.0.0",
  "description": "WebClawProxy - 将各大模型 Web 页面封装成标准 API 接口的代理服务",
  "main": "dist/controller/index.js",
  "scripts": {
    "build": "tsc",
    "build:desktop": "pnpm --filter webclaw-console run build",
    "build:all": "pnpm build && pnpm build:desktop",
    "start": "node dist/controller/index.js",
    "start:desktop": "pnpm --filter webclaw-console run start",
    "dev": "ts-node src/controller/index.ts",
    "dev:desktop": "pnpm --filter webclaw-console run dev",
    "test": "jest",
    "test:web-driver": "jest tests/web-driver",
    "test:protocol": "jest tests/protocol",
    "test:data-manager": "jest tests/data-manager",
    "test:controller": "jest tests/controller",
    "script:protocol": "ts-node scripts/test-protocol.ts",
    "script:data-manager": "ts-node scripts/test-data-manager.ts",
    "script:web-driver": "ts-node scripts/test-web-driver.ts",
    "script:all": "ts-node scripts/test-all.ts",
    "client": "ts-node tui/src/index.ts"
  },
  "keywords": [
    "proxy",
    "ai",
    "openai",
    "llm",
    "web-automation"
  ],
  "author": "fuguoheng",
  "license": "MIT",
  "dependencies": {
    "config": "^3.3.9",
    "crypto": "^1.0.1",
    "express": "^4.18.2",
    "playwright": "^1.42.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverage": false,
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}

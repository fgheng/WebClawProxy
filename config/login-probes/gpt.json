{
  "positiveSignals": [
    {
      "id": "gpt_sidebar_visible",
      "kind": "selector_visible",
      "selector": "aside, nav[aria-label*='Chat'], [class*='sidebar']",
      "weight": 1.2
    },
    {
      "id": "gpt_history_exists",
      "kind": "selector_exists",
      "selector": "nav a[href*='/c/'], [data-testid*='conversation'], [class*='history'] li",
      "weight": 1.4
    },
    {
      "id": "gpt_user_menu",
      "kind": "selector_visible",
      "selector": "button[aria-haspopup='menu'], [data-testid*='user-menu'], [class*='avatar']",
      "weight": 1.2
    },
    {
      "id": "gpt_input_ready",
      "kind": "selector_visible",
      "selector": "textarea, [contenteditable='true']",
      "weight": 0.8
    }
  ],
  "negativeSignals": [
    {
      "id": "gpt_login_btn",
      "kind": "text_visible",
      "texts": ["登录", "log in", "sign in"],
      "weight": 1.6
    },
    {
      "id": "gpt_login_url",
      "kind": "url_regex",
      "pattern": "/login|/signin|auth",
      "weight": 2.0
    }
  ]
}

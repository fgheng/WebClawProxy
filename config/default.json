{
  "data": {
    "root_dir": "./data"
  },
  "providers": {
    "gpt": {
      "default_mode": "web",
      "models": ["gpt-3.5-turbo", "gpt-4", "gpt-4o", "gpt-4-turbo", "gpt-4o-mini", "gpt-5", "gpt-5.1", "gpt-5.2", "o1", "o1-mini", "o3", "o3-mini"],
      "web": {
        "site": "https://chatgpt.com/",
        "input_max_chars": 60000
      }
    },
    "qwen": {
      "default_mode": "web",
      "models": ["qwen-turbo", "qwen-plus", "qwen-max", "qwen-long", "qwen2.5-72b", "qwen2.5-32b"],
      "web": {
        "site": "https://chat.qwen.ai/",
        "input_max_chars": 120000
      }
    },
    "deepseek": {
      "default_mode": "web",
      "models": ["deepseek-chat", "deepseek-r1", "deepseek-v3", "deepseek-coder"],
      "web": {
        "site": "https://chat.deepseek.com/",
        "input_max_chars": 120000
      },
      "forward": {
        "base_url": "https://api.deepseek.com",
        "api_key": "YOUR_DEEPSEEK_API_KEY",
        "upstream_model_map": {
          "deepseek-chat": "deepseek-chat",
          "deepseek-r1": "deepseek-chat",
          "deepseek-v3": "deepseek-chat",
          "deepseek-coder": "deepseek-chat"
        }
      }
    },
    "kimi": {
      "default_mode": "web",
      "models": ["moonshot-v1-8k", "moonshot-v1-32k", "moonshot-v1-128k", "kimi"],
      "web": {
        "site": "https://www.kimi.com/",
        "input_max_chars": 120000
      }
    },
    "glm": {
      "default_mode": "web",
      "models": ["glm", "glm-4", "glm-4-air", "glm-4-plus", "glm-4-flash", "glm-4.5", "glm-5", "glm-5.1"],
      "web": {
        "site": "https://chatglm.cn/",
        "input_max_chars": 15000
      }
    }
  },
  "defaults": {
    "init_prompt": "From now on, output only valid JSON according to the following rules:\n\n[[output_rules.md]]\n\n[[output_template.json]]",
    "init_prompt_template": "{{init_prompt}}\n\n{{system_prompt}}\n\n{{tools_prompt}}\n\n{{history_prompt}}\n\n{{init_prompt}}\n\nOnly reply “Received” in the required format.",
    "user_message_template": "{{content}}",
    "response_schema_template": "[[output_template.json]]",
    "format_only_retry_template": "[[retry_template.md]]"
  },
  "server": {
    "port": 3000
  },
  "context_switch": {
    "_comment": "当一个 web 页面的聊天记录过于cha session",
    "enabled": true,
    "max_prompt_tokens": 120000,
    "max_total_tokens": 128000
  },
  "web_input": {
    "_comment": "当首轮返回非 JSON 且需要重试时：若原始输入长度超过该阈值，则使用仅格式提醒模板；否则使用格式+用户内容模板。",
    "retry_format_only_threshold_chars":  500
  },
  "webdriver": {
    "response_timeout_ms": 120000,
    "stability_check_interval_ms": 500,
    "stability_check_count": 3,
    "headless": false,
    "startup_preflight_enabled": false,
    "startup_open_sites_enabled": true
  },
  "logging": {
    "enabled": true,
    "debug": true,
    "dir": "./data/logs",
    "file_prefix": "webclaw-proxy",
    "pretty_json": false,
    "pretty_json_indent": 4,
    "request_body_truncate_enabled": false,
    "request_body_max_chars": 5000
  }
}

  "prompt": {
    "init_prompt": "All subsequent replies should strictly follow JSON formatting. The agreed rules are as follows:\n\n[[output_rules.md]]\n\n[[output_template.json]]\n",
    "init_prompt_template": "{{init_prompt}}\n\n{{system_prompt}}\n\n{{tools_prompt}}\n\n{{history_prompt}}\n\nOnly reply “Received” in the required JSON format for this message.",
    "user_message_template": "{{content}}\n\nRespond in the required JSON format.",
    "response_schema_template": "[[output_template.json]]",
    "format_only_retry_template": "Not a valid JSON response. Please re-answer the previous question in the required JSON format."
  },
  "server": {
    "port": 3000
  },
  "context_switch": {
    "_comment": "当一个 web 页面的聊天记录过于cha session",
    "enabled": true,
    "max_prompt_tokens": 120000,
    "max_total_tokens": 128000
  },
  "web_input": {
    "_comment": "当首轮返回非 JSON 且需要重试时：若原始输入长度超过该阈值，则使用仅格式提醒模板；否则使用格式+用户内容模板。",
    "retry_format_only_threshold_chars": 500
  },
  "webdriver": {
    "response_timeout_ms": 120000,
    "stability_check_interval_ms": 500,
    "stability_check_count": 3,
    "headless": false,
    "startup_preflight_enabled": false,
    "startup_open_sites_enabled": true
  },
  "logging": {
    "enabled": true,
    "debug": true,
    "dir": ".data/logs",
    "file_prefix": "webclaw-proxy",
    "pretty_json": false,
    "pretty_json_indent": 4,
    "request_body_truncate_enabled": false,
    "request_body_max_chars": 5000
  }
}